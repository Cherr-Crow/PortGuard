<Window x:Class="PortWerks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Port Werks - Professional Red Team Scanner"
        Height="800" Width="1200"
        Background="#0f0f0f"
        WindowStartupLocation="CenterScreen" Icon="/port-werks.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" Style="{StaticResource HardwarePanel}" Background="#2b0425">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="PORT GOURD" FontSize="32" FontWeight="Bold"
                               Foreground="#960e80" FontFamily="Consolas"/>
                    <TextBlock FontSize="12"
                               Foreground="#888" FontFamily="Consolas" Margin="0,0,0,5"><Run Language="ru-ru" Text="Сканер портов"/><Run Text=" "/><Run Language="ru-ru" Text="и аудита безопасности"/></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#888" FontFamily="Consolas" Margin="0,0,5,0"><Run Language="ru-ru" Text="СИСТЕМА"/><Run Text=":"/></TextBlock>
                    <Ellipse x:Name="StatusLED" Style="{StaticResource LEDIndicator}" Fill="#00ff00"/>
                    <TextBlock x:Name="StatusText" Foreground="#00ff00"
                               FontFamily="Consolas" FontWeight="Bold" Margin="8,0,0,0"><Run Text="RE"/><Run Text="ADY"/></TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Control Panel -->
        <Border Grid.Row="1" Style="{StaticResource HardwarePanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Target Configuration -->
                <Grid Grid.Row="0" Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Foreground="#960e80" FontFamily="Consolas"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"><Run Text="IP"/><Run Language="ru-ru" Text=" адрес"/><Run Text=":"/></TextBlock>
                    <TextBox x:Name="TargetTextBox" Grid.Column="1" Style="{StaticResource MetalTextBox}"
                             Text="127.0.0.1" TextChanged="TargetTextBox_TextChanged"/>

                    <TextBlock Grid.Column="2" Foreground="#960e80" FontFamily="Consolas"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,10,0"><Run Language="ru-ru" Text="ПОРТЫ"/><Run Text=":"/></TextBlock>
                    <TextBox x:Name="PortsTextBox" Grid.Column="3" Style="{StaticResource MetalTextBox}"
                             Text="80,443,22,21,3389"/>
                </Grid>

                <!-- Scan Options -->
                <Grid Grid.Row="1" Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SCAN TECHNIQUE" Foreground="#888" FontFamily="Consolas" FontSize="10"/>
                        <ComboBox x:Name="ScanTechniqueCombo" SelectedIndex="0" SelectionChanged="ScanTechniqueCombo_SelectionChanged">
                            <ComboBoxItem Content="TCP Connect"/>
                            <ComboBoxItem Content="SYN Scan (Stealth)"/>
                            <ComboBoxItem Content="UDP Scan"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="0"/>

                    <StackPanel Grid.Column="1" Margin="10,0"/>

                    <StackPanel Grid.Column="2" Margin="10,0"/>

                    <StackPanel Grid.Column="3" Margin="10,0"/>
                </Grid>

                <!-- Feature Toggles & Controls -->
                <Grid Grid.Row="2" Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="ServiceDetectionCheck" Grid.Column="0" Content="Обнаружение сервисов"
                              Foreground="#e0e0e0" FontFamily="Consolas" IsChecked="True" Margin="0,0,20,0" />
                    <CheckBox x:Name="OsFingerprintCheck" Grid.Column="1" Content="Определение ОС"
                              Foreground="#e0e0e0" FontFamily="Consolas" Margin="0,0,20,0"/>
                    <CheckBox x:Name="VersionDetectionCheck" Grid.Column="2" Content="Определение версий ПО"
                              Foreground="#e0e0e0" FontFamily="Consolas" IsChecked="True" Margin="0,0,20,0"/>

                    <Button x:Name="ScanButton" Grid.Column="4" Style="{StaticResource MetalButton}"
                            Content="▶ НАЧАТЬ" Click="ScanButton_Click" Width="150" Margin="5,0"/>
                    <Button x:Name="StopButton" Grid.Column="5" Style="{StaticResource MetalButton}"
                            Content="⬛ СТОП" Click="StopButton_Click" Width="100" Margin="5,0"
                            IsEnabled="False"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Results Display -->
        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Main Results -->
            <Border Grid.Column="0" Style="{StaticResource HardwarePanel}" Background="#4a043e">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="299*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Foreground="#960e80"
                               FontFamily="Consolas" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"><Run Language="ru-ru" Text="РЕЗУЛЬТАТ СКАНИРОВАНИЯ"/></TextBlock>

                    <DataGrid x:Name="ResultsDataGrid"
                              Background="#1c0014" Foreground="#e0e0e0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#333"
                              HeadersVisibility="Column"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FontFamily="Consolas"
                              RowBackground="#0f0f0f"
                              AlternatingRowBackground="#1a1a1a"
                              BorderBrush="#555" SelectionChanged="ResultsDataGrid_SelectionChanged" Margin="0,26,0,0" Grid.RowSpan="3">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="LightBlue"/>
                                <Setter Property="Foreground" Value="DarkBlue"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="Height" Value="30"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="80"/>
                            <DataGridTextColumn Header="STATE" Binding="{Binding State}" Width="100"/>
                            <DataGridTextColumn Header="PROTOCOL" Binding="{Binding Protocol}" Width="80"/>
                            <DataGridTextColumn Header="SERVICE" Binding="{Binding ServiceName}" Width="120"/>
                            <DataGridTextColumn Header="VERSION" Binding="{Binding ServiceVersion}" Width="150"/>
                            <DataGridTextColumn Header="RESPONSE (ms)" Binding="{Binding ResponseTime}" Width="120"/>
                            <DataGridTextColumn Header="BANNER" Binding="{Binding Banner}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Statistics Panel -->
            <Border Grid.Column="1" Style="{StaticResource HardwarePanel}" Background="#4a043e">
                <StackPanel>
                    <TextBlock Foreground="#960e80" FontFamily="Consolas"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,15"><Run Language="ru-ru" Text="СТАТИСТИКА"/></TextBlock>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"><Run Language="ru-ru" Text="ПРОСКАНИРОВАНО ПОРТОВ"/></TextBlock>
                        <TextBlock x:Name="PortsScannedText" Text="0 / 0" Foreground="#e0e0e0"
                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"><Run Language="ru-ru" Text="ОТКРЫТЫЕ ПОРТЫ"/></TextBlock>
                        <TextBlock x:Name="OpenPortsText" Text="0" Foreground="#006400"
                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"><Run Language="ru-ru" Text="ЗАКРЫТЫЕ ПОРТЫ"/></TextBlock>
                        <TextBlock x:Name="ClosedPortsText" Text="0" Foreground="#ff3333"
                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"><Run Language="ru-ru" Text="ФИЛЬТРУЕМЫЕ ПОРТЫ"/></TextBlock>
                        <TextBlock x:Name="FilteredPortsText" Text="0" Foreground="#ffaa00"
                                   FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"><Run Language="ru-ru" Text="СКОРОСТЬ СКАНИРОВАНИЯ"/></TextBlock>
                        <TextBlock x:Name="ScanSpeedText" Foreground="#e0e0e0"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"><Run Text="0 "/><Run Language="ru-ru" Text="п"/><Run Text="/"/><Run Language="ru-ru" Text="с"/></TextBlock>
                    </StackPanel>

                    <ProgressBar x:Name="ScanProgressBar" Height="20" Margin="0,15,0,5"
                                 Background="#1c0014" BorderBrush="#555" Foreground="#00ff00"/>
                    <TextBlock x:Name="ProgressText" Text="0%" Foreground="#888"
                               FontFamily="Consolas" TextAlignment="Center"/>

                    <Separator Margin="0,20,0,15" Background="#555"/>

                    <TextBlock Text="EXPORT" Foreground="#00ff00" FontFamily="Consolas"
                               FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="JSON" Style="{StaticResource MetalButton}" Click="ExportJson_Click" Margin="0,2"/>
                    <Button Content="XML" Style="{StaticResource MetalButton}" Click="ExportXml_Click" Margin="0,2"/>
                    <Button Content="CSV" Style="{StaticResource MetalButton}" Click="ExportCsv_Click" Margin="0,2"/>
                    <Button Content="HTML Report" Style="{StaticResource MetalButton}" Click="ExportHtml_Click" Margin="0,2"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Console Output -->
        <Border Grid.Row="3" Style="{StaticResource HardwarePanel}" Background="#1c0014" Height="150">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="125*"/>
                    <ColumnDefinition Width="258*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="25*"/>
                    <RowDefinition Height="84*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Foreground="#960e80"
                           FontFamily="Consolas" FontWeight="Bold" Margin="0,0,0,5" Grid.ColumnSpan="2"><Run Language="ru-ru" Text="КОНСОЛЬ"/></TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="2" Margin="0,19,0,0" Grid.RowSpan="3">
                    <TextBlock x:Name="ConsoleOutput" Foreground="#960e80" FontFamily="Consolas"
                               FontSize="11" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
